# bex CI secrets — TEMPLATE (safe to commit; no real values here).
#
# These are GitHub Actions secrets, NOT a local runtime env. The workflows
# (infra.yml / app-cluster.yml / deploy.yml) read them via ${{ secrets.* }}.
#
# Usage:
#   cp .env.template .env        # .env is gitignored — NEVER commit the filled one
#   <fill in the values below>
#   bash scripts/gh-secrets.sh   # pushes them into GitHub Actions secrets via `gh`
#
# Or set them by hand: GitHub → repo Settings → Secrets and variables → Actions.

# --- Hetzner Cloud ---
# Console → project → Security → API Tokens → generate (Read & Write).
HCLOUD_TOKEN=

# --- SSH key for the infra node (give the FILE PATHS, not the key material) ---
# Create once:  ssh-keygen -t ed25519 -f ~/.ssh/bex -C bex
BEX_SSH_PUBLIC_KEY_FILE=$HOME/.ssh/bex.pub
BEX_SSH_PRIVATE_KEY_FILE=$HOME/.ssh/bex

# --- Terraform remote state: Hetzner Object Storage (S3-compatible) ---
# Create the bucket once (the one out-of-band "bottom turtle"), then its S3 creds.
TF_STATE_BUCKET=bex-tfstate
TF_STATE_ENDPOINT=https://fsn1.your-objectstorage.com
TF_STATE_REGION=fsn1
TF_STATE_ACCESS_KEY=
TF_STATE_SECRET_KEY=
