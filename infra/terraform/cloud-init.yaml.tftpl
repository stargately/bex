#cloud-config
# Single-node k3s = the bex infra (management) cluster. CAPH is installed on top
# afterwards via `clusterctl init` (README phase 2). traefik is disabled — bex
# brings its own ingress/gateway; this node only needs to host CAPI controllers.
runcmd:
  - PUBIP=$(curl -s --max-time 5 http://169.254.169.254/hetzner/v1/metadata/public-ipv4)
  - curl -sfL https://get.k3s.io | INSTALL_K3S_CHANNEL=${k3s_channel} sh -s - --disable traefik --write-kubeconfig-mode 644 --tls-san "$PUBIP"
